# ========== 部署前请复制为 .env 并修改 ==========
# cp .env.example .env

# ----- 你的域名（绑定到服务器公网 IP 的 A 记录） -----
DOMAIN=shop.example.com

# nginx-certbot 用于 Let's Encrypt 注册的邮箱
CERTBOT_EMAIL=admin@example.com
# 调试时设为 1 用 staging 证书避免触发速率限制；正式部署设为 0
LETSENCRYPT_STAGING=0

# ----- 数据库（首次部署可保留默认；上线后建议改强密码） -----
DB_NAME=taiwanshangcheng
DB_USERNAME=vendure
DB_PASSWORD=please-change-me-in-production

# ----- Vendure ----- 
COOKIE_SECRET=please-change-me-to-random-32-chars
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin

# ----- 前后端跨域 -----
# 这里 = 你的网站域名（用 https）。多个用逗号分隔
FRONTEND_ORIGINS=https://shop.example.com

# ----- 浏览器调用后端的 URL（必须是公开 HTTPS 域名） -----
NEXT_PUBLIC_VENDURE_SHOP_API_URL=https://shop.example.com/shop-api
